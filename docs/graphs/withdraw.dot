digraph withdraw {
  rankdir=TB;
  node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#EAF4FF", color="#1F5A99"];
  edge [fontname="Helvetica", fontsize=9, color="#444444"];

  start [label="Début", shape=ellipse, fillcolor="#D5F5E3", color="#1E8449"];
  n1 [label="Appeler apply_transaction\n(type = withdraw)"];
  d1 [label="Compte trouvé ?", shape=diamond, fillcolor="#FFF3CD", color="#B9770E"];
  d2 [label="Solde insuffisant ?", shape=diamond, fillcolor="#FFF3CD", color="#B9770E"];
  n2 [label="Diminuer balance"];
  n3 [label="Créer transaction withdraw"];
  n4 [label="Écrire le fichier JSON"];
  ok [label="Retour HTTP 200", shape=ellipse, fillcolor="#D5F5E3", color="#1E8449"];
  ko404 [label="Retour HTTP 404", shape=ellipse, fillcolor="#FADBD8", color="#C0392B"];
  ko400 [label="Retour HTTP 400\n(solde insuffisant)", shape=ellipse, fillcolor="#FADBD8", color="#C0392B"];

  start -> n1 -> d1;
  d1 -> ko404 [label="Non"];
  d1 -> d2 [label="Oui"];
  d2 -> ko400 [label="Oui"];
  d2 -> n2 [label="Non"];
  n2 -> n3 -> n4 -> ok;
}
